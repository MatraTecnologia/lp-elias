---
import { whatsappLink } from "../data/site";
---

<a
  class="wa"
  href={whatsappLink("Olá, Elias! Vim pelo site e gostaria de conversar.")}
  target="_blank"
  rel="noopener"
  aria-label="Conversar no WhatsApp"
  data-wa-float
>
  <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true" fill="currentColor">
    <path
      d="M17.5 14.4c-.3-.2-1.7-.9-2-1-.3-.1-.5-.2-.6.1-.2.3-.7 1-.9 1.1-.2.2-.3.2-.6.1-.3-.2-1.2-.5-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.6-1.5-.9-2.1-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.2.3-.9.9-.9 2.2s.9 2.5 1 2.7c.1.2 1.8 2.8 4.4 3.9.6.3 1.1.4 1.5.5.6.2 1.2.2 1.6.1.5-.1 1.7-.7 1.9-1.3.2-.7.2-1.2.2-1.3-.1-.2-.3-.2-.5-.4z M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.5A10 10 0 1 0 12 2zm0 18.2a8.2 8.2 0 0 1-4.2-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2z"
    ></path>
  </svg>
</a>

<style>
  .wa {
    position: fixed;
    right: clamp(1rem, 3vw, 1.8rem);
    bottom: clamp(1rem, 3vw, 1.8rem);
    z-index: 60;
    width: 54px;
    height: 54px;
    display: grid;
    place-items: center;
    color: var(--ink);
    background: var(--copper);
    border-radius: 50%;
    box-shadow: 0 10px 30px -8px rgba(0, 0, 0, 0.7);
    transform: translateY(80px);
    opacity: 0;
    transition:
      transform 0.4s var(--ease),
      opacity 0.4s var(--ease),
      background 0.3s var(--ease);
  }
  .wa[data-show] {
    transform: none;
    opacity: 1;
  }
  .wa:hover {
    background: var(--paper);
  }
  @media (prefers-reduced-motion: reduce) {
    .wa {
      transition: opacity 0.3s;
    }
  }
</style>

<script>
  const wa = document.querySelector("[data-wa-float]") as HTMLElement;
  const onScroll = () => {
    if (window.scrollY > window.innerHeight * 0.7) wa.setAttribute("data-show", "");
    else wa.removeAttribute("data-show");
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>

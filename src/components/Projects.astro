---
import { Image, getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import SectionHead from "./SectionHead.astro";
import { whatsappLink } from "../data/site";
import { projects } from "../data/projects";

const glob = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/projetos/*/*.{png,jpg,jpeg}",
  { eager: true },
);

const meta = (slug: string, file: string) => {
  const asset = glob[`../assets/projetos/${slug}/${file}`];
  if (!asset) throw new Error(`Imagem não encontrada: ${slug}/${file}`);
  return asset.default;
};

const tiles = await Promise.all(
  projects.map(async (p, i) => {
    const cover = meta(p.slug, p.images[0]);
    const gallery = await Promise.all(
      p.images.map(async (file) => {
        const optimized = await getImage({
          src: meta(p.slug, file),
          widths: [900, 1600],
          format: "webp",
        });
        return optimized.src;
      }),
    );
    return { ...p, cover, gallery, featured: i === 0 };
  }),
);

const filters = ["Todos", "Residencial", "Comercial"] as const;
---

<section class="prj" id="projetos">
  <div class="container">
    <div class="prj__head" data-reveal>
      <SectionHead eyebrow="Projetos">
        Projetos que saíram<br />do papel para a obra.
        <Fragment slot="intro">
          Uma seleção de residências e espaços comerciais desenhados e
          conduzidos por Elias — do Estudo de volumetria, fechadas externas e
          ambientes internos
        </Fragment>
      </SectionHead>
      <a
        class="btn btn--ghost prj__cta"
        href={whatsappLink(
          "Olá, Elias! Gostaria de conhecer mais projetos executados.",
        )}
        target="_blank"
        rel="noopener">Falar sobre o meu projeto</a
      >
    </div>

    <div
      class="prj__filters"
      data-reveal
      role="tablist"
      aria-label="Filtrar projetos"
    >
      {
        filters.map((f, i) => (
          <button
            class="prj__filter"
            data-filter={f}
            aria-pressed={i === 0 ? "true" : "false"}
          >
            {f}
          </button>
        ))
      }
    </div>

    <ul class="prj__grid" id="prj-grid">
      {
        tiles.map((t, i) => (
          <li
            class:list={["prj__tile", { "prj__tile--feat": t.featured }]}
            data-category={t.category}
            data-title={t.title}
            data-scope={t.scope}
            data-gallery={JSON.stringify(t.gallery)}
            data-reveal
            style={`--reveal-delay: ${(i % 3) * 70}ms`}
          >
            <button
              class="prj__open"
              type="button"
              aria-label={`Ver projeto ${t.title}`}
            >
              <Image
                class="prj__img"
                src={t.cover}
                alt={t.title}
                widths={t.featured ? [640, 900, 1280] : [420, 640, 900]}
                sizes={
                  t.featured
                    ? "(max-width: 900px) 100vw, 66vw"
                    : "(max-width: 900px) 100vw, 33vw"
                }
                loading="lazy"
              />
              <span class="prj__overlay" aria-hidden="true" />
              <span class="prj__meta">
                <span class="prj__tag">{t.category}</span>
                <span class="prj__info">
                  <span class="prj__title">{t.title}</span>
                  <span class="prj__scope">
                    {t.location ? `${t.location} · ${t.scope}` : t.scope}
                  </span>
                </span>
              </span>
              {t.gallery.length > 1 && (
                <span class="prj__count" aria-hidden="true">
                  {t.gallery.length} fotos
                </span>
              )}
            </button>
          </li>
        ))
      }
    </ul>
    <p class="prj__empty" hidden>Nenhum projeto nesta categoria.</p>
  </div>

  <div class="lb" id="prj-lb" hidden aria-hidden="true">
    <div class="lb__backdrop" data-lb-close></div>
    <div
      class="lb__stage"
      role="dialog"
      aria-modal="true"
      aria-label="Galeria do projeto"
    >
      <button class="lb__x" type="button" aria-label="Fechar" data-lb-close
        >&times;</button
      >
      <button
        class="lb__nav lb__nav--prev"
        type="button"
        aria-label="Anterior"
        data-lb-prev
      >
        &#8592;</button
      >
      <figure class="lb__figure">
        <img class="lb__img" alt="" />
        <figcaption class="lb__cap">
          <span class="lb__title"></span>
          <span class="lb__counter"></span>
        </figcaption>
      </figure>
      <button
        class="lb__nav lb__nav--next"
        type="button"
        aria-label="Próxima"
        data-lb-next
      >
        &#8594;</button
      >
    </div>
  </div>
</section>

<style>
  .prj {
    padding-block: var(--section-y);
    border-top: 1px solid var(--line-soft);
  }
  .prj__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .prj__cta {
    flex: none;
  }

  .prj__filters {
    display: flex;
    gap: 0.5rem;
    margin-top: clamp(2rem, 4vw, 3rem);
    flex-wrap: wrap;
  }
  .prj__filter {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--paper-dim);
    padding: 0.55rem 1.1rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    transition:
      color 0.3s var(--ease),
      border-color 0.3s var(--ease),
      background 0.3s var(--ease);
  }
  .prj__filter:hover {
    color: var(--paper);
    border-color: var(--paper-faint);
  }
  .prj__filter[aria-pressed="true"] {
    color: var(--ink);
    background: var(--copper);
    border-color: var(--copper);
  }

  .prj__grid {
    list-style: none;
    padding: 0;
    margin-top: 1.4rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }
  .prj__tile {
    margin: 0;
  }
  .prj__tile--feat {
    grid-column: span 2;
    grid-row: span 2;
  }

  .prj__open {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--ink-2);
    aspect-ratio: 4 / 3;
  }
  .prj__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition:
      transform 0.7s var(--ease),
      filter 0.5s var(--ease);
    filter: saturate(0.96) contrast(1.02);
  }
  .prj__open:hover .prj__img {
    transform: scale(1.045);
  }
  .prj__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(12, 11, 10, 0.86) 0%,
      rgba(12, 11, 10, 0.32) 42%,
      rgba(12, 11, 10, 0) 68%
    );
  }
  .prj__meta {
    position: absolute;
    inset: auto 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 1.2rem 1.3rem 1.25rem;
    text-align: left;
  }
  .prj__tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--copper);
    align-self: flex-start;
  }
  .prj__info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .prj__title {
    font-family: var(--font-display);
    font-size: var(--step-1);
    line-height: 1.1;
    color: var(--paper);
  }
  .prj__tile--feat .prj__title {
    font-size: var(--step-2);
  }
  .prj__scope {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    color: var(--paper-dim);
  }
  .prj__count {
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--paper);
    background: rgba(12, 11, 10, 0.55);
    backdrop-filter: blur(4px);
    padding: 0.3rem 0.55rem;
    border: 1px solid rgba(243, 239, 232, 0.14);
  }
  .prj__tile[hidden] {
    display: none;
  }
  .prj__empty {
    margin-top: 2rem;
    color: var(--paper-dim);
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }

  /* — Lightbox — */
  .lb {
    position: fixed;
    inset: 0;
    z-index: 90;
    display: grid;
    place-items: center;
    padding: clamp(1rem, 4vw, 3rem);
  }
  .lb[hidden] {
    display: none;
  }
  .lb__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(6, 5, 5, 0.92);
    backdrop-filter: blur(6px);
    animation: lb-fade 0.3s var(--ease);
  }
  .lb__stage {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: clamp(0.5rem, 2vw, 1.5rem);
    max-width: min(1180px, 100%);
    width: 100%;
  }
  .lb__figure {
    margin: 0;
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .lb__img {
    max-width: 100%;
    max-height: 78vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border: 1px solid var(--line);
    animation: lb-fade 0.35s var(--ease);
  }
  .lb__cap {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .lb__title {
    font-family: var(--font-display);
    font-size: var(--step-1);
    color: var(--paper);
  }
  .lb__counter {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.14em;
    color: var(--paper-dim);
  }
  .lb__x {
    position: absolute;
    top: -2.6rem;
    right: 0;
    font-size: 2rem;
    line-height: 1;
    color: var(--paper-dim);
    transition: color 0.25s var(--ease);
  }
  .lb__x:hover {
    color: var(--copper);
  }
  .lb__nav {
    flex: none;
    width: 3rem;
    height: 3rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--paper);
    font-size: 1.15rem;
    display: grid;
    place-items: center;
    transition:
      border-color 0.25s var(--ease),
      background 0.25s var(--ease);
  }
  .lb__nav:hover {
    border-color: var(--copper);
    background: rgba(200, 121, 74, 0.12);
  }

  @keyframes lb-fade {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @media (max-width: 900px) {
    .prj__grid {
      grid-template-columns: 1fr 1fr;
    }
    .prj__tile--feat {
      grid-column: span 2;
      grid-row: auto;
    }
    .prj__tile--feat .prj__open {
      aspect-ratio: 16 / 10;
    }
  }
  @media (max-width: 560px) {
    .prj__grid {
      grid-template-columns: 1fr;
    }
    .prj__tile--feat {
      grid-column: auto;
    }
    .lb__nav {
      width: 2.5rem;
      height: 2.5rem;
    }
  }
</style>

<script>
  const grid = document.getElementById("prj-grid");
  const tiles = Array.from(
    document.querySelectorAll<HTMLElement>(".prj__tile"),
  );
  const filterBtns = Array.from(
    document.querySelectorAll<HTMLButtonElement>(".prj__filter"),
  );
  const empty = document.querySelector<HTMLElement>(".prj__empty");

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const value = btn.dataset.filter;
      filterBtns.forEach((b) =>
        b.setAttribute("aria-pressed", String(b === btn)),
      );
      let visible = 0;
      tiles.forEach((tile) => {
        const show = value === "Todos" || tile.dataset.category === value;
        tile.hidden = !show;
        if (show) visible++;
      });
      if (empty) empty.hidden = visible > 0;
    });
  });

  // — Lightbox —
  const lb = document.getElementById("prj-lb")!;
  const lbImg = lb.querySelector<HTMLImageElement>(".lb__img")!;
  const lbTitle = lb.querySelector<HTMLElement>(".lb__title")!;
  const lbCounter = lb.querySelector<HTMLElement>(".lb__counter")!;
  let current: string[] = [];
  let index = 0;

  const render = () => {
    lbImg.src = current[index];
    lbCounter.textContent = `${index + 1} / ${current.length}`;
  };
  const move = (dir: number) => {
    index = (index + dir + current.length) % current.length;
    render();
  };
  const open = (gallery: string[], title: string) => {
    current = gallery;
    index = 0;
    lbTitle.textContent = title;
    render();
    lb.hidden = false;
    lb.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  };
  const close = () => {
    lb.hidden = true;
    lb.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  };

  tiles.forEach((tile) => {
    tile.querySelector(".prj__open")?.addEventListener("click", () => {
      const gallery = JSON.parse(tile.dataset.gallery || "[]") as string[];
      open(gallery, tile.dataset.title || "");
    });
  });

  lb.querySelectorAll("[data-lb-close]").forEach((el) =>
    el.addEventListener("click", close),
  );
  lb.querySelector("[data-lb-prev]")?.addEventListener("click", () => move(-1));
  lb.querySelector("[data-lb-next]")?.addEventListener("click", () => move(1));

  document.addEventListener("keydown", (e) => {
    if (lb.hidden) return;
    if (e.key === "Escape") close();
    else if (e.key === "ArrowLeft") move(-1);
    else if (e.key === "ArrowRight") move(1);
  });
</script>

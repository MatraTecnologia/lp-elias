---
import SectionHead from "./SectionHead.astro";
import { method } from "../data/site";
---

<section class="mth" id="metodo">
  <div class="container">
    <div data-reveal>
      <SectionHead eyebrow="Método">
        Uma obra conduzida<br />tem ordem, não sorte.
        <Fragment slot="intro">
          Cada etapa é planejada, executada e verificada antes de começar a
          próxima. Nada avança no improviso.
        </Fragment>
      </SectionHead>
    </div>

    <div class="mth__track" data-reveal>
      <div class="mth__line" aria-hidden="true">
        <span class="mth__line-fill"></span>
      </div>
      <ol class="mth__steps">
        {
          method.map((m) => (
            <li class="mth__step">
              <span class="mth__node" aria-hidden="true" />
              <span class="mth__stage">Etapa {m.step}</span>
              <h3 class="mth__title">{m.title}</h3>
              <p class="mth__body">{m.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style>
  .mth {
    padding-block: var(--section-y);
    border-top: 1px solid var(--line-soft);
  }

  .mth__track {
    margin-top: clamp(3rem, 6vw, 5rem);
    position: relative;
  }
  .mth__line {
    position: absolute;
    top: 5px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--line);
  }
  .mth__line-fill {
    display: block;
    height: 100%;
    background: var(--copper);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1.4s var(--ease) 0.2s;
  }
  .mth__track:global(.is-in) .mth__line-fill,
  :global([data-reveal].is-in) .mth__line-fill {
    transform: scaleX(1);
  }

  .mth__steps {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  .mth__step {
    position: relative;
    padding-top: 2.4rem;
    padding-right: 1.2rem;
  }
  .mth__node {
    position: absolute;
    top: 0;
    left: 0;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--ink);
    border: 1px solid var(--copper);
  }
  .mth__node::after {
    content: "";
    position: absolute;
    inset: 3px;
    border-radius: 50%;
    background: var(--copper);
    transform: scale(0);
    transition: transform 0.4s var(--ease) 0.6s;
  }
  :global([data-reveal].is-in) .mth__node::after {
    transform: scale(1);
  }
  .mth__stage {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--paper-faint);
  }
  .mth__title {
    font-family: var(--font-display);
    font-size: var(--step-2);
    margin: 0.9rem 0 0.8rem;
  }
  .mth__body {
    color: var(--paper-dim);
    font-size: var(--step--1);
    line-height: 1.6;
  }

  @media (prefers-reduced-motion: reduce) {
    .mth__line-fill,
    .mth__node::after {
      transform: none;
    }
  }

  @media (max-width: 820px) {
    .mth__line {
      top: 0;
      bottom: 0;
      left: 5px;
      right: auto;
      width: 1px;
      height: auto;
    }
    .mth__line-fill {
      width: 100%;
      height: 100%;
      transform: scaleY(0);
      transform-origin: top;
    }
    :global([data-reveal].is-in) .mth__line-fill {
      transform: scaleY(1);
    }
    .mth__steps {
      grid-template-columns: 1fr;
      gap: 2.6rem;
    }
    .mth__step {
      padding-top: 0;
      padding-left: 2.4rem;
    }
    .mth__node {
      top: 6px;
      left: 0;
    }
  }
</style>
